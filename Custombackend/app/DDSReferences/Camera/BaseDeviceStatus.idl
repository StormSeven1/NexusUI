
module casia {
module device {
module status {

/**
 * 执行状态枚举
 */
enum ExecutionState {
    EXECUTING,           // 执行中
    COMPLETED,          // 已完成
    ALREADY_CLEARED,    // 已取消
    SAVED,              // 暂存中
    FAILED              // 已失败
};


/**
 * 地理位置结构
 */
struct GeoPosition {
    double longitude;        // 经度
    double latitude;         // 纬度
    double altitude;         // 高度（米）
};

/**
 * 基础设备状态
 */
struct BaseDeviceStatus {
    string entityId;    // 设备唯一标识符
    string taskType;         // 当前执行的任务类型
    ExecutionState executionState;    // 执行状态
    unsigned long executionTimeMs;    // 执行时间（毫秒）
    boolean online;                   // 在线状态
    GeoPosition position;             // 地理位置
    double elec;                      // 电量百分比
    string timestamp;                 // 数据采集时间戳
};

}; // module status
}; // module device
}; // module casia

