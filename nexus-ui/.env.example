# 复制为 nexus-ui/.env.local 后重启 npm run dev。
# 每个 KEY 在 .env 里只能生效一行：下面「————」下第一组为联网默认可跑；离线/备选整段在注释里，切换时注释掉当前生效段、取消注释目标段（或只改样式/底图几行）。

################################################################################
# 二维 MapLibre
################################################################################

# —— 联网：Carto GL 矢量样式（需外网）——
NEXT_PUBLIC_MAP2D_STYLE_URL=https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json
NEXT_PUBLIC_MAP2D_MINI_STYLE_URL=https://basemaps.cartocdn.com/gl/dark-matter-nolabels-gl-style/style.json
NEXT_PUBLIC_MAP2D_INITIAL_CENTER=120.217,38.105
NEXT_PUBLIC_MAP2D_INITIAL_ZOOM=10

# 为 true：2D 地图不绘制航迹点/线/标牌（列表与 track-store 仍更新）。默认不写或 false。
# NEXT_PUBLIC_DISABLE_MAP_TRACK_RENDERING=true

# —— 离线：同源 JSON（public/map-styles/offline-map.json），瓦片在 JSON 里写 pmtiles://…；见 public/tiles/README.txt ——
# NEXT_PUBLIC_MAP2D_STYLE_URL=/map-styles/offline-map.json
# NEXT_PUBLIC_MAP2D_MINI_STYLE_URL=/map-styles/offline-map.json
# NEXT_PUBLIC_MAP2D_INITIAL_CENTER=120.217,38.105
# NEXT_PUBLIC_MAP2D_INITIAL_ZOOM=10

################################################################################
# 三维 Cesium（底图仅一条 URL 模板，无内置默认；离线请改为内网或本机可访问的 XYZ）
################################################################################

# —— 联网：示例为 Carto 深色栅格 XYZ（需外网；可整行改成任意其它 XYZ 模板）——
NEXT_PUBLIC_MAP3D_IMAGERY_URL=https://basemaps.cartocdn.com/dark_all/{z}/{x}/{y}@2x.png
NEXT_PUBLIC_MAP3D_INITIAL_CENTER=120.217,38.105
NEXT_PUBLIC_MAP3D_INITIAL_ZOOM=10

# —— 离线：示例为内网自托管 XYZ（按你实际服务改主机与路径）——
# NEXT_PUBLIC_MAP3D_IMAGERY_URL=http://192.168.1.10/tiles/{z}/{x}/{y}.png
# NEXT_PUBLIC_MAP3D_INITIAL_CENTER=120.217,38.105
# NEXT_PUBLIC_MAP3D_INITIAL_ZOOM=10

################################################################################
# 后端（Next rewrites 代理目标）
################################################################################

BACKEND_URL=http://127.0.0.1:27003

################################################################################
# 相机 / 设备注册 / WebRTC（服务端；见 app/api/eo-drone-registry、eo-webrtc-sources）
################################################################################
# NEXUS_ENTITIES_LIST_URL=http://192.168.18.141:8090/api/v1/entities?page=1&size=100
# CAMERA_ENTITY_BASE_URL=http://192.168.18.141:8088

################################################################################
# 无人机 / 私有云 / MQTT（服务端；见 app/api/uav-control）
################################################################################
# 无人机平台根 URL（与私有云同一地址时只设这一项即可；旧名 NEXUS_DRONE_PRIVATE_CLOUD_BASE_URL / NEXUS_UAV_PLATFORM_BASE_URL 仍可作备选）
# NEXUS_DRONE_PLATFORM_BASE_URL=http://192.168.18.141:8890
# NEXUS_DRONE_PRIVATE_CLOUD_BASE_URL=
# NEXUS_UAV_PLATFORM_BASE_URL=
# NEXUS_DRONE_PLATFORM_USERNAME=adminPC
# NEXUS_DRONE_PLATFORM_PASSWORD=
# NEXUS_UAV_TASK_API_BASE_URL=
# NEXUS_UAV_TASK_OWNER_ENTITY_ID=uav-001
# NEXUS_UAV_MQTT_BROKER_URL=
# NEXUS_UAV_MQTT_USERNAME=
# NEXUS_UAV_MQTT_PASSWORD=
# NEXUS_UAV_CTRL_TAKEOFF_DEFAULT_HEIGHT_M=120
# NEXUS_UAV_CTRL_AIRPORT_DEFAULT_LAT=
# NEXUS_UAV_CTRL_AIRPORT_DEFAULT_LON=

################################################################################
# 光电视频客户端（NEXT_PUBLIC_*）
################################################################################
# NEXT_PUBLIC_MQTT_WS_URL=
# NEXT_PUBLIC_EO_DETECTION_WS_URL=
# NEXT_PUBLIC_NEXUS_UAV_ZLM_WEBRTC_BASE_URL=
# NEXT_PUBLIC_UAV_ZLM_WEBRTC_BASE=
# NEXT_PUBLIC_ZLM_WEBRTC_PORT=1985
# NEXT_PUBLIC_APP_CONFIG_URL=
# NEXT_PUBLIC_BASE_PATH=
