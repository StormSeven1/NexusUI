# 复制为 nexus-ui/.env.local 后重启 npm run dev。
# 每个 KEY 在 .env 里只能生效一行：下面「————」下第一组为联网默认可跑；离线/备选整段在注释里，切换时注释掉当前生效段、取消注释目标段（或只改样式/底图几行）。

################################################################################
# 二维 MapLibre
################################################################################

# —— 联网：Carto GL 矢量样式（需外网）——
NEXT_PUBLIC_MAP2D_STYLE_URL=https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json
NEXT_PUBLIC_MAP2D_MINI_STYLE_URL=https://basemaps.cartocdn.com/gl/dark-matter-nolabels-gl-style/style.json
NEXT_PUBLIC_MAP2D_INITIAL_CENTER=120.217,38.105
NEXT_PUBLIC_MAP2D_INITIAL_ZOOM=10

# —— 离线：同源 JSON（public/map-styles/offline-map.json），瓦片在 JSON 里写 pmtiles://…；见 public/tiles/README.txt ——
# NEXT_PUBLIC_MAP2D_STYLE_URL=/map-styles/offline-map.json
# NEXT_PUBLIC_MAP2D_MINI_STYLE_URL=/map-styles/offline-map.json
# NEXT_PUBLIC_MAP2D_INITIAL_CENTER=120.217,38.105
# NEXT_PUBLIC_MAP2D_INITIAL_ZOOM=10

################################################################################
# 三维 Cesium（底图仅一条 URL 模板，无内置默认；离线请改为内网或本机可访问的 XYZ）
################################################################################

# —— 联网：示例为 Carto 深色栅格 XYZ（需外网；可整行改成任意其它 XYZ 模板）——
NEXT_PUBLIC_MAP3D_IMAGERY_URL=https://basemaps.cartocdn.com/dark_all/{z}/{x}/{y}@2x.png
NEXT_PUBLIC_MAP3D_INITIAL_CENTER=120.217,38.105
NEXT_PUBLIC_MAP3D_INITIAL_ZOOM=10

# —— 离线：示例为内网自托管 XYZ（按你实际服务改主机与路径）——
# NEXT_PUBLIC_MAP3D_IMAGERY_URL=http://192.168.1.10/tiles/{z}/{x}/{y}.png
# NEXT_PUBLIC_MAP3D_INITIAL_CENTER=120.217,38.105
# NEXT_PUBLIC_MAP3D_INITIAL_ZOOM=10

################################################################################
# 后端（Next rewrites 代理目标）
################################################################################

BACKEND_URL=http://localhost:8001
